{
  "name": "rainpath-workflow-editor",
  "version": "0.0.0",
  "private": true,
  "description": "Éditeur visuel de workflows de relance patient pour laboratoires d'anatomopathologie",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:schemas": "pnpm --filter @rainpath/schemas build",
    "dev": "pnpm build:schemas && concurrently -k -n api,web -c blue,green \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "build": "pnpm build:schemas && pnpm --filter api build && pnpm --filter web build",
    "test": "pnpm build:schemas && pnpm -r test",
    "test:cov": "pnpm build:schemas && pnpm -r test --coverage",
    "typecheck": "pnpm build:schemas && pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:reset": "pnpm --filter api db:reset",
    "db:reset:empty": "pnpm --filter api db:reset:empty",
    "db:seed": "pnpm --filter api db:seed",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.41",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
